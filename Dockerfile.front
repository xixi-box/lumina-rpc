# ============================================================
# Frontend Dockerfile (纯 Nginx 托管)
# 由 GitHub Actions 构建产物，服务器只需运行
# ============================================================

FROM nginx:alpine

# 复制 GitHub Actions 传过来的 dist 产物
COPY lumina-dashboard/dist /usr/share/nginx/html

# 复制 nginx 配置
COPY lumina-dashboard/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]