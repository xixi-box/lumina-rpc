# ============================================================
# Lumina-RPC 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# MySQL 数据库（Zeabur 环境变量）
DB_USER=lumina
DB_PASS=your_secure_password_here

# 可选：MySQL Root 密码
# DB_ROOT_PASS=your_root_password_here

# 前端配置（如果需要）
# VITE_API_BASE_URL=/api