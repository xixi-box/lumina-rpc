# ============================================================
# Lumina-RPC 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# MySQL 数据库，本地开发默认值与 docker-compose.yml/application.yml 保持一致
MYSQL_ROOT_PASSWORD=lumina123
MYSQL_DATABASE=lumina
MYSQL_USER=lumina
MYSQL_PASSWORD=lumina123
MYSQL_PORT=3306

# 兼容部分 PaaS 的变量命名，应用配置会按 MYSQL_PASSWORD -> DB_PASS -> 本地默认值读取
DB_USER=lumina
DB_PASS=lumina123

# 控制面运行参数
LOG_LEVEL=INFO
MYBATIS_LOG=org.apache.ibatis.logging.slf4j.Slf4jImpl
REGISTRY_INSTANCE_TTL_SECONDS=90
REGISTRY_CLEANUP_FIXED_RATE_MS=60000
REGISTRY_ZOMBIE_RETENTION_HOURS=1
SSE_TIMEOUT_MS=1800000
SSE_HEARTBEAT_INTERVAL_SECONDS=30

# 前端配置（如果需要）
# VITE_API_BASE_URL=/api
